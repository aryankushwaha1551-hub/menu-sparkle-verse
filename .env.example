# MenuVerse — public frontend variables only.
# Never commit real .env files. Never place service-role or secret keys here.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Server-only (Lovable Cloud injects these automatically in production):
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # never expose to the browser
